{
	"info": {
		"_postman_id": "8b5d38c6-6593-4a16-95a7-9f6b9c9f2b84",
		"name": "AI Observability Backend",
		"description": "API endpoints for the Kubernetes AI Observability Backend. Requires port-forwarding the Kubernetes service to localhost:8001.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Probes",
			"item": [
				{
					"name": "Liveness Probe",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/live",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"live"
							]
						},
						"description": "Returns 200 OK if the API process is running."
					},
					"response": []
				},
				{
					"name": "Readiness Probe",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/ready",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"ready"
							]
						},
						"description": "Returns readiness state of the Database, Redis queue, and Gemini API."
					},
					"response": []
				}
			]
		},
		{
			"name": "Observability Data",
			"item": [
				{
					"name": "Recent Metrics",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-API-Key",
								"value": "{{api_key}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/metrics/recent",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"metrics",
								"recent"
							]
						},
						"description": "Returns the last 100 raw Kubernetes pod metrics collected from Prometheus."
					},
					"response": []
				},
				{
					"name": "Recent Anomalies",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-API-Key",
								"value": "{{api_key}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/anomalies",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"anomalies"
							]
						},
						"description": "Returns detected anomalies based on rolling-window z-score deviations."
					},
					"response": []
				},
				{
					"name": "AI Insights",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-API-Key",
								"value": "{{api_key}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/insights",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"insights"
							]
						},
						"description": "Returns root-cause analysis generated by Gemini 2.5 Flash for recent anomalies."
					},
					"response": []
				},
				{
					"name": "Cluster Incidents",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-API-Key",
								"value": "{{api_key}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/cluster/incidents",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"cluster",
								"incidents"
							]
						},
						"description": "Returns a cluster-wide SRE incident correlation report. Aggregates all anomalies, metrics, and dependency data from the last hour and uses Gemini to identify the top 5 most critical incidents with root causes, impact analysis, and actionable recommendations. Cached for 60 seconds."
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8001"
		},
		{
			"key": "api_key",
			"value": "your-api-key-here"
		}
	]
}
